{
  "manifest_version": 3,
  "name": "WebLayer",
  "description": "Sends website content to a local WebLayer daemon and applies returned decisions.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://www.x.com/*",
        "*://twitter.com/*",
        "*://www.twitter.com/*"
      ],
      "js": ["siteAdapters.js", "contentScript.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "WebLayer"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "weblayer@rndhouse",
      "data_collection_permissions": {
        "required": ["websiteActivity", "websiteContent"]
      }
    }
  }
}
